# .env.example — copy to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Load: source .env       (or `make run`, which loads .env automatically)
# Run:  source .env && cd dc-api && ./dc-api
#
# Variables marked REQUIRED will cause dc-api to fail-fast on startup if
# missing. Variables marked OPTIONAL have sensible defaults documented in
# dc-api/internal/config/config.go.

# ── Database ─────────────────────────────────────────────────────────────────
# Matches docker-compose.yaml defaults. Change password if you customised it.
# REQUIRED.
export DCAPI_DB_URL="postgres://dc_api:dc_dev_password@localhost:5432/dc_api?sslmode=disable"

# ── OIDC ─────────────────────────────────────────────────────────────────────
# REQUIRED. dc-api validates incoming JWTs against this issuer.
# Asgardeo: https://api.asgardeo.io/t/<org>
# Keycloak: https://keycloak.example.com/realms/<realm>
# Okta:     https://<domain>.okta.com/oauth2/default
export DCAPI_OIDC_ISSUER="https://api.asgardeo.io/t/<org>"

# REQUIRED. Comma-separated list of accepted "aud" claim values. List EVERY
# client whose tokens dc-api should honour:
#   - The dcctl public client (PKCE)
#   - The cloud-ui SPA client (if running the UI)
#   - The BFF confidential client (if BFF is enabled below)
#   - Any future client (e.g. a Terraform provider's client)
# A token is accepted when at least one of its audience values matches.
export DCAPI_OIDC_AUDIENCE="<dcctl-client-id>,<cloud-ui-client-id>"

# OPTIONAL. The ONLY IdP group dc-api interprets: members get platform-admin.
# Tenant membership lives exclusively in the role_assignments table (invites),
# never in IdP groups.
export DCAPI_ADMIN_GROUP="dc-admin"

# OPTIONAL. Comma-separated list of Asgardeo `sub` values that should bypass
# per-tenant RBAC (platform admins). Decouples admin status from any IdP-side
# group machinery — useful for break-glass access.
# export DCAPI_PLATFORM_ADMIN_SUBS="sub-uuid-1,sub-uuid-2"

# ── Harvester ────────────────────────────────────────────────────────────────
# REQUIRED. Base64-encoded kubeconfig for the Harvester cluster.
#   macOS: base64 -i ~/.kube/harvester.yaml | tr -d '\n'
#   Linux: base64 -w0 < ~/.kube/harvester.yaml
# This kubeconfig is reused by the network provider (KubeOVN runs on the same
# Harvester cluster) — you don't need a second one.
export DCAPI_HARVESTER_KUBECONFIG="<base64-harvester-kubeconfig>"

# OPTIONAL. Harvester namespace where dc-api creates tenant resources when
# no tenant-derived namespace exists. Tenant VMs always land in
# `dc-<tenant>-<project>` (M2.5 hierarchy).
export DCAPI_HARVESTER_NAMESPACE="default"

# ── Rancher ──────────────────────────────────────────────────────────────────
# REQUIRED.
export DCAPI_RANCHER_URL="https://rancher.example.com"

# REQUIRED. API token from Rancher UI → User Settings → API Keys → Create
# (no scope, no expiry).
export DCAPI_RANCHER_TOKEN="token-xxxxx:yyyyyyyyyyyyyy"

# OPTIONAL. Set true if Rancher uses a self-signed certificate (typical for
# a dev cluster). Default false.
export DCAPI_RANCHER_INSECURE="true"

# REQUIRED. Name of the cloud-credential secret you create ONCE in the Rancher
# UI: Cluster Management → Cloud Credentials → Create → Harvester. Paste the
# Harvester kubeconfig there. The secret name is shown in the UI in the form
# `cattle-global-data:cc-xxxxx` — copy it verbatim.
# dc-api uses this credential to spin up RKE2 cluster node VMs on Harvester.
export DCAPI_RANCHER_HARVESTER_CREDENTIAL="cattle-global-data:cc-xxxxx"

# ── Operator break-glass credentials (cluster node VMs) ──────────────────────
# OPTIONAL but recommended. Injected via cloud-init into every cluster node so
# the IaaS team can SSH / console in when Rancher access is unavailable.
# OPERATOR_SSH_KEY is the public key (~/.ssh/id_ed25519.pub content).
# OPERATOR_PASSWORD is the recovery-console password.
# Either or both may be empty — features that need them will simply skip
# the cloud-init injection.
export DCAPI_OPERATOR_SSH_KEY=""
export DCAPI_OPERATOR_PASSWORD=""

# ── Provider selection ───────────────────────────────────────────────────────
# OPTIONAL. Only "harvester" is supported for compute, "rancher" for clusters,
# "kubeovn" for networking. Leave these as defaults.
export DCAPI_VM_PROVIDER="harvester"
export DCAPI_CLUSTER_PROVIDER="rancher"
export DCAPI_NETWORK_PROVIDER="kubeovn"

# OPTIONAL. Namespace where KubeOVN's daemon pods live on Harvester. Matches
# the standard KubeOVN Helm install layout.
export DCAPI_KUBEOVN_NAMESPACE="kube-ovn"

# ── KubeOVN VPC external network (F15) ───────────────────────────────────────
# REQUIRED when DCAPI_NETWORK_PROVIDER=kubeovn (the default). dc-api uses these
# to create the cluster-scoped ProviderNetwork / Vlan / Subnet / NAD that every
# tenant VPC's NAT gateway SNATs through.
#
# - BRIDGE  : the Linux bridge on Harvester hosts connected to the upstream
#             router (matches the host NIC / bond name, e.g. "mgmt-br").
# - CIDR    : full CIDR of the external network (e.g. "192.168.10.0/24").
# - GATEWAY : real upstream gateway IP inside the CIDR.
# - RESERVED_IPS : comma-separated IPs KubeOVN's IPAM must skip — host nodes,
#                  Harvester VIP, ingress LBs, anything already pinned on the
#                  external network. Empty is allowed.
# - VLAN_ID : 0 = untagged. Set to a VLAN tag if the upstream switch trunks.
#
# dc-api validates these at startup and refuses to boot on missing or invalid
# values (see config.ValidateF15).
export DCAPI_VPC_EXTERNAL_BRIDGE="mgmt-br"
export DCAPI_VPC_EXTERNAL_CIDR="192.168.10.0/24"
export DCAPI_VPC_EXTERNAL_GATEWAY="192.168.10.254"
export DCAPI_VPC_EXTERNAL_RESERVED_IPS=""
export DCAPI_VPC_EXTERNAL_VLAN_ID="0"

# ── KubeOVN per-VPC CoreDNS (F20) ────────────────────────────────────────────
# OPTIONAL. Defaults to 1.1.1.1,8.8.8.8 with the in-cluster CoreDNS image
# auto-detected. Override if you need a private DNS resolver or air-gapped image.
export DCAPI_VPC_DNS_FORWARDERS="1.1.1.1,8.8.8.8"
# export DCAPI_VPC_DNS_IMAGE=""           # empty = auto-detect
# export DCAPI_VPC_DNS_SEARCH_DOMAIN=""   # e.g. "lk.dc.internal"

# ── Cluster + Bastion management NIC (F10 / F32) ─────────────────────────────
# OPTIONAL. Multus NetworkAttachmentDefinition (`namespace/name`) for the
# outbound-internet NIC attached to every RKE2 cluster node and bastion VM.
# This must be a bridge NAD on a VLAN reachable from your workstation/VPN,
# NOT a NAD over an infra-reserved bridge (see DCAPI_INFRA_RESERVED_NADS).
export DCAPI_CLUSTER_MGMT_NAD="iaas/vm-network-001"
export DCAPI_BASTION_MGMT_NAD="iaas/vm-network-001"
# OPTIONAL. Image used for bastion hosts (`namespace/resource-name`).
export DCAPI_BASTION_IMAGE="rancher-infra/ubuntu-22-04"

# ── F21 infra-reserved NADs ──────────────────────────────────────────────────
# OPTIONAL. Comma-separated list of `namespace/nad-name` references that
# tenant VMs MUST NOT attach to via the legacy bridge path. Default protects
# the known-bad dc-api/dc-api-mgmt NAD. Extend if you claim additional
# bridges for infra use.
export DCAPI_INFRA_RESERVED_NADS="dc-api/dc-api-mgmt"

# ── M3 Key Vault backend (chunk 2) ───────────────────────────────────────────
# OPTIONAL. In-cluster DNS name + port of the OpenBao Service that every
# Key Vault Private Endpoint proxies to. Defaults match the M3 chunk-2
# in-Harvester layout; override when OpenBao runs in a different namespace
# or on a dedicated cluster.
export DCAPI_KV_BACKEND_ADDR="openbao.dc-api-vault.svc.cluster.local"
export DCAPI_KV_BACKEND_PORT="8200"

# ── BFF (cloud-ui session-cookie auth) ───────────────────────────────────────
# OPTIONAL. Leave blank to disable. When set, dc-api serves
#   /v1/auth/{login,callback,logout,me}
# and accepts a dcapi_session cookie on /v1/* in addition to Bearer headers.
# Use this only if you're running cloud-ui locally and want session-based login.
# dcctl never needs this — it always uses Bearer tokens.
#
# BFF_SESSION_SECRET must be a base64-encoded 32-byte key:
#   openssl rand -base64 32
export DCAPI_BFF_CLIENT_ID=""
export DCAPI_BFF_CLIENT_SECRET=""
export DCAPI_BFF_SESSION_SECRET=""
export DCAPI_BFF_REDIRECT_URL="http://localhost:8080/v1/auth/callback"
export DCAPI_BFF_POST_LOGIN_REDIRECT="http://localhost:5173/"
export DCAPI_BFF_POST_LOGOUT_REDIRECT="http://localhost:5173/"
export DCAPI_BFF_COOKIE_DOMAIN=""
export DCAPI_BFF_COOKIE_SECURE="false"

# ── IdP SCIM2 directory (optional, read-only) ────────────────────────────────
# OPTIONAL. Leave all four unset to disable. When set, dc-api proxies live,
# read-only SCIM2 lookups against your IdP to power the invite picker
# (GET /v1/tenants/{tid}/directory/{users,groups}) and invite-by-email
# (user_email on POST .../role-assignments). Nothing from the IdP is stored
# — only the resolved OIDC `sub` lands on the
# role_assignments row.
#
# The four below must be set together: dc-api refuses to start on a partial
# set (catches "the secret didn't reach the deployment" early). DCAPI_IDP_SCOPES
# is optional and excluded from that check.
#
# The OAuth2 client_credentials app MUST hold user/group VIEW scopes only
# (Asgardeo: internal_user_mgt_view + internal_group_mgt_view) — dc-api never
# writes to the IdP.
#
# Asgardeo examples:
# export DCAPI_IDP_SCIM_BASE_URL="https://api.asgardeo.io/t/<org>/scim2"
# export DCAPI_IDP_TOKEN_URL="https://api.asgardeo.io/t/<org>/oauth2/token"
# export DCAPI_IDP_CLIENT_ID="<m2m-app-client-id>"
# export DCAPI_IDP_CLIENT_SECRET="<m2m-app-client-secret>"
#
# DCAPI_IDP_SCOPES — OAuth2 scopes requested with the client_credentials grant
# (space- or comma-separated). REQUIRED for Asgardeo / WSO2 Identity Server:
# they only attach SCIM permissions to the token when scopes are requested, so
# without these every SCIM call returns 403. Other IdPs may need none (leave
# unset). WARNING: grant LIST/VIEW scopes ONLY — never write scopes; dc-api is
# read-only against the IdP.
# export DCAPI_IDP_SCOPES="internal_user_mgt_list internal_user_mgt_view internal_group_mgt_view"
#
# DCAPI_IDP_USERSTORE_DOMAIN — restricts directory reads to one userstore via
# the WSO2 SCIM2 `domain` query parameter. Without it the IdP returns EVERY
# account in the organization — including console administrators and
# collaborators, who are not invite candidates. Default "DEFAULT" (Asgardeo's
# consumer-user store); on-prem WSO2 Identity Server typically wants
# "PRIMARY". Set explicitly empty to list all stores; non-WSO2 SCIM servers
# ignore the parameter.
# export DCAPI_IDP_USERSTORE_DOMAIN="DEFAULT"

# ── Server ───────────────────────────────────────────────────────────────────
export DCAPI_LOG_LEVEL="debug"      # debug for local dev; info for prod
export DCAPI_LISTEN_ADDR=":8080"
